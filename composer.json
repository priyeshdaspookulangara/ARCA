{
    "name": "your-vendor/modular-erp",
    "type": "project",
    "description": "A Highly Modular ERP System.",
    "keywords": ["erp", "modular", "php", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0",
        "arca-modules/auth-mgt": "*",
        "erp-modules/crm": "*",
        "arca-modules/ehs": "*",
        "arca-modules/ewm": "*",
        "erp-modules/fina": "*",
        "arca-modules/grc": "*",
        "erp-modules/hr": "*",
        "arca-modules/is-retail": "*",
        "erp-modules/lscm": "*",
        "arca-modules/mdg": "*",
        "arca-modules/plm": "*",
        "erp-modules/ps": "*",
        "erp-modules/mm": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.5",
        "fakerphp/faker": "^1.9.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/module_path.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Modules\\Fina\\Tests\\": "modules/Fina/tests/",
            "Modules\\HR\\Tests\\": "modules/HR/tests/",
            "Modules\\MM\\Tests\\": "modules/MM/tests/",
            "Modules\\Fina\\Database\\Factories\\": "modules/Fina/database/factories/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Modules\\MM\\Providers\\MMServiceProvider"
            ],
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "modules/*",
            "options": {
                "symlink": true
            }
        }
    ]
}

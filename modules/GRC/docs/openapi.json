{
  "openapi": "3.0.0",
  "info": {
    "title": "ARCA GRC API",
    "version": "1.0.0",
    "description": "API for the Governance, Risk & Compliance (GRC) module of the ARCA ERP system."
  },
  "paths": {
    "/api/grc/roles": {
      "get": {
        "summary": "List all roles",
        "responses": {
          "200": {
            "description": "A list of roles."
          }
        }
      },
      "post": {
        "summary": "Create a new role",
        "responses": {
          "201": {
            "description": "The created role."
          }
        }
      }
    },
    "/api/grc/roles/{id}": {
      "get": {
        "summary": "Get a specific role",
        "responses": {
          "200": {
            "description": "The requested role."
          }
        }
      },
      "put": {
        "summary": "Update a role",
        "responses": {
          "200": {
            "description": "The updated role."
          }
        }
      },
      "delete": {
        "summary": "Delete a role",
        "responses": {
          "204": {
            "description": "No content."
          }
        }
      }
    },
    "/api/grc/permissions": {
      "get": {
        "summary": "List all permissions",
        "responses": {
          "200": {
            "description": "A list of permissions."
          }
        }
      },
      "post": {
        "summary": "Create a new permission",
        "responses": {
          "201": {
            "description": "The created permission."
          }
        }
      }
    },
    "/api/grc/permissions/{id}": {
      "get": {
        "summary": "Get a specific permission",
        "responses": {
          "200": {
            "description": "The requested permission."
          }
        }
      },
      "put": {
        "summary": "Update a permission",
        "responses": {
          "200": {
            "description": "The updated permission."
          }
        }
      },
      "delete": {
        "summary": "Delete a permission",
        "responses": {
          "204": {
            "description": "No content."
          }
        }
      }
    },
    "/api/grc/audit/query": {
      "get": {
        "summary": "Query audit logs",
        "responses": {
          "200": {
            "description": "A list of audit log entries."
          }
        }
      }
    },
    "/api/grc/sod-rules": {
      "get": {
        "summary": "List all SoD rules",
        "responses": {
          "200": {
            "description": "A list of SoD rules."
          }
        }
      },
      "post": {
        "summary": "Create a new SoD rule",
        "responses": {
          "201": {
            "description": "The created SoD rule."
          }
        }
      }
    },
    "/api/grc/sod-rules/{id}": {
      "get": {
        "summary": "Get a specific SoD rule",
        "responses": {
          "200": {
            "description": "The requested SoD rule."
          }
        }
      },
      "put": {
        "summary": "Update an SoD rule",
        "responses": {
          "200": {
            "description": "The updated SoD rule."
          }
        }
      },
      "delete": {
        "summary": "Delete an SoD rule",
        "responses": {
          "204": {
            "description": "No content."
          }
        }
      }
    },
    "/api/grc/check-policy": {
      "post": {
        "summary": "Check a transaction against SoD rules",
        "responses": {
          "200": {
            "description": "The result of the policy check (allow, warn, block)."
          }
        }
      }
    },
    "/api/grc/consents": {
      "get": {
        "summary": "List all consents",
        "responses": {
          "200": {
            "description": "A list of consent records."
          }
        }
      },
      "post": {
        "summary": "Create a new consent record",
        "responses": {
          "201": {
            "description": "The created consent record."
          }
        }
      }
    },
    "/api/grc/consents/{id}": {
      "get": {
        "summary": "Get a specific consent record",
        "responses": {
          "200": {
            "description": "The requested consent record."
          }
        }
      },
      "put": {
        "summary": "Update a consent record",
        "responses": {
          "200": {
            "description": "The updated consent record."
          }
        }
      },
      "delete": {
        "summary": "Delete a consent record",
        "responses": {
          "204": {
            "description": "No content."
          }
        }
      }
    },
    "/api/grc/data-request": {
      "post": {
        "summary": "Submit a data access request (e.g., export, erasure)",
        "responses": {
          "200": {
            "description": "The status of the data request."
          }
        }
      }
    }
  }
}